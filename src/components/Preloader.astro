---
import { projects } from "../data/site";
---

<div id="preloader" data-count={projects.length}>
  <div class="odometer">000</div>
  <div class="pl-label">Initializing experience</div>
  <div class="pl-bar"><i></i></div>
  <button class="button-start" type="button">Enter</button>
</div>

<script is:inline>
  (() => {
    const pre = document.getElementById("preloader");
    if (!pre) return;
    const odo = pre.querySelector(".odometer");
    const bar = pre.querySelector(".pl-bar > i");
    const label = pre.querySelector(".pl-label");
    const start = pre.querySelector(".button-start");

    let p = 0;
    let ready = false;
    const render = () => {
      const v = Math.min(100, Math.round(p));
      if (odo) odo.textContent = String(v).padStart(3, "0");
      if (bar) bar.style.width = v + "%";
    };

    // ramp toward 90 while the heavy island loads, then finish on ready
    const tick = setInterval(() => {
      const ceiling = ready ? 100 : 90;
      p += (ceiling - p) * 0.08 + 0.4;
      if (p >= ceiling) p = ceiling;
      render();
      if (ready && p >= 99.5) {
        clearInterval(tick);
        p = 100;
        render();
        pre.classList.add("is-ready");
        if (label) label.textContent = "Ready";
      }
    }, 40);

    const skip = new URLSearchParams(location.search).has("skipintro");
    const onReady = () => {
      ready = true;
      if (skip) setTimeout(() => dismiss(), 400);
    };
    window.addEventListener("experience:ready", onReady, { once: true });
    // fallback so the button always appears even if hydration is slow
    setTimeout(onReady, 6000);

    function dismiss() {
      pre.classList.add("is-leaving");
      window.dispatchEvent(new Event("experience:start"));
      setTimeout(() => pre.remove(), 1100);
    }
    start?.addEventListener("click", dismiss);
  })();
</script>
